{
    "version": 2,
    "builds": [
        {
            "src": "index.js",
            "use": "@vercel/node"
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "index.js"
        },
        {
            "src": "/(.*)",
            "dest": "/$1"
        },
        {
            "src": "/services/(.*)",
            "dest": "/services/$1"
        },
        {
            "src": "/(.*).html",
            "dest": "/$1.html"
        },
        {
            "src": "/",
            "dest": "/index.html"
        }
    ]
}